# Server
PORT=4000
# Local: http://localhost:3000
# Production (comma-separated): https://your-app.vercel.app,https://your-app-git-main.vercel.app
FRONTEND_ORIGIN=http://localhost:3000
DEMO_USER_PHONE=+919876543210

JWT_SECRET=change-me-in-production
ADMIN_EMAIL=admin@jewelry.com
ADMIN_PASSWORD=admin123

# Customer OTP — dev mode uses a fixed code in the database (no SMS)
OTP_DEV_MODE=true
OTP_DEV_CODE=123456
# Twilio Verify (set OTP_DEV_MODE=false when ready)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
# Transactional SMS (order, delivery, returns) — use a Twilio phone number OR Messaging Service SID
# TWILIO_SMS_FROM=+1xxxxxxxxxx
# TWILIO_MESSAGING_SERVICE_SID=
# WhatsApp (Twilio sandbox or approved WhatsApp sender)
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# ADMIN_ALERT_PHONE=+919876543210
# STORE_NAME=Dhrumil Jewellers

# Razorpay (live or test keys from dashboard.razorpay.com)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Shiprocket (API user from Settings → API → Configure)
# SHIPROCKET_EMAIL=
# SHIPROCKET_PASSWORD=
# Exact "Address Nickname" from Shiprocket → Settings → Pickup locations (not the PRIMARY badge)
# SHIPROCKET_PICKUP_LOCATION=work-1
# Warehouse address (return shipments are delivered here)
# SHIPROCKET_WAREHOUSE_NAME=Wholesale Jewelry
# SHIPROCKET_WAREHOUSE_ADDRESS=Your warehouse street address
# SHIPROCKET_WAREHOUSE_CITY=Mumbai
# SHIPROCKET_WAREHOUSE_STATE=Maharashtra
# SHIPROCKET_WAREHOUSE_PINCODE=400001
# SHIPROCKET_WAREHOUSE_PHONE=9999999999
# SHIPROCKET_WAREHOUSE_EMAIL=warehouse@example.com
# Optional custom channel id from Shiprocket panel
# SHIPROCKET_CHANNEL_ID=
# Webhook: Settings → Additional Settings → Webhooks (Token = same value; header x-api-key)
# SHIPROCKET_WEBHOOK_SECRET=your-random-secret
# URL: https://your-api-domain/api/shiprocket/webhook

# PostgreSQL — use ONE of the options below:

# Standard local Postgres (pgAdmin, Docker, installed Postgres):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wholesale_jewelry?schema=public"

# Prisma local dev database (run `npx prisma dev` in another terminal):
# DATABASE_URL is auto-set in .env when you use `npx prisma init` with Prisma Postgres

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wholesale_jewelry?schema=public"
